FROM node:12.18

WORKDIR /usr/src/app

# Install all deps from the root package.json (it carries both
# frontend and backend dependencies — bcrypt, express, mongoose, etc.)
COPY package.json package-lock.json ./
RUN npm install --legacy-peer-deps

# Copy the backend source. The rest of the project is mounted at
# runtime via docker-compose for live reload during development.
COPY backend ./backend

EXPOSE 3000

CMD ["node", "backend/server.js"]
